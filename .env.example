# Supabase — copy this file to `.env` and fill in your project values.
# Find them in Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Vibe Analyzer & Hit Scoring microservice (services/vibe-analyzer).
# Defaults to localhost — point this at your deployed instance in production.
VITE_VIBE_ANALYZER_URL=http://localhost:8000

# Market Intelligence (Roster → Analytics panel). Chartmetric or Soundcharts
# is the real path to cross-platform streaming/demographic data — Spotify
# and Apple don't publish that publicly. SERVER-ONLY (no VITE_ prefix) —
# these are read inside a server function (src/lib/market-config.ts), never
# sent to the browser. Leave unset to keep the panel in its "not connected"
# empty state.
CHARTMETRIC_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
APPLE_MUSIC_TOKEN=

# Soundcharts (developers.soundcharts.com) — same category as Chartmetric,
# and specifically what powers the TikTok "sound scanner" panel on the
# TikTok campaign dashboard (creations/likes/views/comments/shares for a
# linked sound — TikTok itself has no public API for that). Uses OAuth2
# client-credentials: create an API client in your Soundcharts dashboard →
# Credentials, then set both values below (both required).
SOUNDCHARTS_CLIENT_ID=
SOUNDCHARTS_CLIENT_SECRET=

# YouTube Data API v3 (console.cloud.google.com/apis/credentials) — a real,
# live source. Restrict it to your domain via HTTP referrer restrictions.
# Also powers real per-video view/like/comment counts on the YouTube
# campaign dashboard once you paste a video link there.
VITE_YOUTUBE_API_KEY=

# Meta Graph API (Facebook Page + Instagram Business insights) — powers the
# Facebook/Instagram campaign dashboards. SERVER-ONLY (no VITE_ prefix).
# Needs a Meta App (developers.facebook.com) + a long-lived Page Access
# Token with pages_read_engagement + read_insights (+ instagram_manage_insights
# for IG). Page Insights only populate once the Page has 100+ likes, and
# tokens expire every ~60 days and need refreshing. META_IG_BUSINESS_ID is
# your Instagram Business account's numeric ID (Graph API Explorer, or your
# Page's linked Instagram account settings) — only needed for the IG panel.
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_BUSINESS_ID=

# Instagram oEmbed (Creators → paste a live post URL for a real embedded
# preview — see src/lib/oembed.ts). Reuses META_PAGE_ACCESS_TOKEN above if
# already set. Only needed as a fallback if you'd rather use a dedicated
# Client Access Token instead: format is `${META_APP_ID}|${META_CLIENT_TOKEN}`,
# both found in your Meta App dashboard → Settings → Advanced. TikTok's
# oEmbed needs no key at all — it's genuinely public.
META_APP_ID=
META_CLIENT_TOKEN=

# Supabase service role key (Dashboard → Project Settings → API → service_role).
# SERVER-ONLY — do NOT prefix with VITE_, never expose this to the browser.
# Powers real invite emails from Admin → Add member.
SUPABASE_SERVICE_ROLE_KEY=

# Secures all three Vercel Cron endpoints (see vercel.json):
#   • api/cron/youtube-snapshot.ts     — daily YouTube view-count snapshot
#   • api/cron/soundcharts-snapshot.ts — daily TikTok sound video-count snapshot
#   • api/cron/weekly-digest.ts        — Monday campaign-brief PDF digest
# Vercel Cron sends this automatically as `Authorization: Bearer <value>`
# once set; generate any random string. Leave unset and the endpoints are
# left open (fine for a single-user personal tool, but set it if that
# bothers you).
CRON_SECRET=

# Your deployed RIPPL URL (e.g. https://rippl-mu.vercel.app). Used as the
# redirect target inside invite emails — without it, Supabase falls back to
# whatever "Site URL" is set in its dashboard (often still localhost:3000,
# which 404s for anyone who isn't you). On Vercel this can be left unset —
# VERCEL_URL is auto-injected — but setting it explicitly is more reliable
# if you're on a custom domain. You ALSO need to add this same URL under
# Supabase → Authentication → URL Configuration → Redirect URLs, or Supabase
# will silently ignore it and use the Site URL default anyway.
VITE_APP_URL=
